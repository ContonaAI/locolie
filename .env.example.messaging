# ──────────────────────────────────────────────────────────────────────────
# locolie - messaging + billing env vars
#
# Documented reference of every credential that switches a demo-mode
# integration to live. Copy the lines you need into your real .env (this file
# is a snippet only - do NOT use it as your .env). After editing the env, run
# `php artisan config:clear`. Leave a var blank/absent to keep that integration
# in demo mode (logged + counted, never sent for real).
# ──────────────────────────────────────────────────────────────────────────

# ── Email ──────────────────────────────────────────────────────────────────
# Any ONE of: Gmail OAuth, Resend, or a non-log default mailer makes email live.

# Gmail / Google Workspace (recommended) - OAuth send from your own domain.
GOOGLE_GMAIL_CLIENT_ID=          # OAuth client id from Google Cloud Console
GOOGLE_GMAIL_CLIENT_SECRET=      # OAuth client secret
GOOGLE_GMAIL_REFRESH_TOKEN=      # Refresh token from the consent flow (flips email live)
GOOGLE_GMAIL_FROM=               # From address, e.g. hello@locolie.com

# Resend - modern transactional email API.
RESEND_API_KEY=                  # API key from the Resend dashboard

# Generic mail transport (SMTP / SES / Postmark). Default is "log" = demo mode.
MAIL_MAILER=log                  # smtp | ses | postmark | resend (anything but log/array = live)
MAIL_HOST=                       # SMTP host
MAIL_PORT=587                    # SMTP port
MAIL_USERNAME=                   # SMTP username
MAIL_PASSWORD=                   # SMTP password
MAIL_FROM_ADDRESS=hello@locolie.com  # Global from address
POSTMARK_API_KEY=                # Only if MAIL_MAILER=postmark

# ── SMS ────────────────────────────────────────────────────────────────────
# Configure any ONE provider. Twilio is fully wired for real delivery.

# Twilio (recommended, real HTTP delivery)
TWILIO_ACCOUNT_SID=              # Account SID from the Twilio console
TWILIO_AUTH_TOKEN=               # Auth token from the Twilio console
TWILIO_FROM=                     # Twilio number or messaging service sender

# Vonage (Nexmo)
VONAGE_API_KEY=                  # API key from the Vonage dashboard
VONAGE_API_SECRET=               # API secret
VONAGE_FROM=                     # Sender id or number

# MessageBird / Bird
MESSAGEBIRD_ACCESS_KEY=          # Access key from the Bird dashboard
MESSAGEBIRD_ORIGINATOR=          # Sender id or number

# Plivo
PLIVO_AUTH_ID=                   # Auth id from the Plivo console
PLIVO_AUTH_TOKEN=                # Auth token
PLIVO_FROM=                      # Plivo number

# ClickSend
CLICKSEND_USERNAME=              # ClickSend account username
CLICKSEND_API_KEY=               # API key from ClickSend
CLICKSEND_FROM=                  # Sender id or number

# AWS SNS (shares the AWS keys below with SES)
AWS_ACCESS_KEY_ID=               # AWS access key (SNS + SES)
AWS_SECRET_ACCESS_KEY=           # AWS secret key
AWS_DEFAULT_REGION=eu-west-1     # AWS region for SNS

# ── Push ───────────────────────────────────────────────────────────────────

# Web Push (VAPID) - browser notifications, no third party. Can go live today.
VAPID_PUBLIC_KEY=                # Public key of the VAPID keypair
VAPID_PRIVATE_KEY=               # Private key of the VAPID keypair
VAPID_SUBJECT=                   # mailto: or URL for the sender (defaults to APP_URL)

# Firebase Cloud Messaging (Android) - lands with the mobile app.
FCM_PROJECT_ID=                  # Firebase project id
FCM_CREDENTIALS=                 # Path to the service-account JSON file

# Apple Push (APNs, iOS) - lands with the mobile app.
APNS_KEY_ID=                     # Key id of the APNs auth key
APNS_TEAM_ID=                    # Apple developer team id
APNS_BUNDLE_ID=                  # App bundle identifier
APNS_AUTH_KEY=                   # Path to the .p8 auth key file

# ── Billing (Stripe) ───────────────────────────────────────────────────────
STRIPE_KEY=                      # Publishable key from the Stripe dashboard
STRIPE_SECRET=                   # Secret key from the Stripe dashboard
STRIPE_PRICE_FEATURED=           # Price id for the Featured plan
STRIPE_PRICE_PREMIUM=            # Price id for the Premium plan

# ── Infrastructure ─────────────────────────────────────────────────────────
QUEUE_CONNECTION=database        # database | redis need a running `php artisan queue:work`; sync runs inline
