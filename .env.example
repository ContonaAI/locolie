APP_NAME=Laravel
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://localhost

APP_LOCALE=en
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=en_US

APP_MAINTENANCE_DRIVER=file
# APP_MAINTENANCE_STORE=database

# PHP_CLI_SERVER_WORKERS=4

BCRYPT_ROUNDS=12

LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

DB_CONNECTION=sqlite
# DB_HOST=127.0.0.1
# DB_PORT=3306
# DB_DATABASE=laravel
# DB_USERNAME=root
# DB_PASSWORD=

SESSION_DRIVER=database
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=null

BROADCAST_CONNECTION=log
FILESYSTEM_DISK=local
QUEUE_CONNECTION=database

CACHE_STORE=database
# CACHE_PREFIX=

MEMCACHED_HOST=127.0.0.1

REDIS_CLIENT=phpredis
REDIS_HOST=127.0.0.1
REDIS_PASSWORD=null
REDIS_PORT=6379

MAIL_MAILER=log
MAIL_SCHEME=null
MAIL_HOST=127.0.0.1
MAIL_PORT=2525
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_FROM_ADDRESS="hello@example.com"
MAIL_FROM_NAME="${APP_NAME}"

AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=us-east-1
AWS_BUCKET=
AWS_USE_PATH_STYLE_ENDPOINT=false

# Google Maps / Places API key (optional — only needed when real Places is enabled)
GOOGLE_MAPS_API_KEY=

VITE_APP_NAME="${APP_NAME}"

# =====================================================================
# Messaging Studio (email / SMS / push)
# Every key below is OPTIONAL. With none set, the studio runs in demo
# mode: sends are logged + counted so the full flow is demoable. Add the
# keys for a channel and that channel goes live with no code change.
# =====================================================================

# --- EMAIL providers --------------------------------------------------
# Resend (transactional email API).
RESEND_API_KEY=
# Mailjet (Send API v3.1 - transactional + campaign, EU/GDPR-friendly).
# Needs both KEY and SECRET to go live; FROM is the verified sender.
MAILJET_KEY=
MAILJET_SECRET=
MAILJET_FROM="hello@locolie.com"
# Google Workspace / Gmail send (OAuth - "Connect to Google" in the studio).
GOOGLE_GMAIL_CLIENT_ID=
GOOGLE_GMAIL_CLIENT_SECRET=
GOOGLE_GMAIL_REFRESH_TOKEN=
GOOGLE_GMAIL_FROM=

# --- SMS providers ----------------------------------------------------
# ClickSend (recommended cheap default). USERNAME + API_KEY are required to
# go live; FROM is an optional sender id (number or alphanumeric).
CLICKSEND_USERNAME=
CLICKSEND_API_KEY=
CLICKSEND_FROM="locolie"
# Twilio.
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_FROM=
# Vonage (Nexmo).
VONAGE_API_KEY=
VONAGE_API_SECRET=
VONAGE_FROM=
# MessageBird / Bird.
MESSAGEBIRD_ACCESS_KEY=
MESSAGEBIRD_ORIGINATOR=
# Plivo.
PLIVO_AUTH_ID=
PLIVO_AUTH_TOKEN=
PLIVO_FROM=
# AWS SNS reuses the AWS_* credentials above for SMS.

# --- PUSH -------------------------------------------------------------
# Web Push (VAPID) - self-generated keypair, no third-party account.
VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
VAPID_SUBJECT="mailto:hello@locolie.com"
# Firebase Cloud Messaging (chosen native client: Android + web).
# Preferred: project id + a service account (inline JSON or a file path).
FCM_PROJECT_ID=
FCM_CREDENTIALS=
# Fallback: legacy FCM HTTP API server key (used when no service account set).
FCM_SERVER_KEY=
# Apple Push Notification service (iOS). AUTH_KEY is the .p8 contents or a path.
APNS_KEY_ID=
APNS_TEAM_ID=
APNS_BUNDLE_ID=
APNS_AUTH_KEY=
